# Required: secret used to sign/encrypt OAuth codes and tokens.
# Generate with: openssl rand -hex 32
MCP_SECRET=replace-me-with-a-strong-random-string-at-least-32-chars

# Optional: forces the issuer URL written into OAuth metadata.
# Set this in production (e.g. https://mcp.famulor.io). When unset, the
# server derives the issuer from the incoming request host.
# MCP_ISSUER=https://mcp.famulor.io

# Optional: only for stdio CLI mode / local dev — used if no bearer token
# is supplied on a request. Production deployments should NOT set this.
# FAMULOR_API_KEY=your-api-key-here

# Optional dev escape hatch: skip the live Famulor /me probe on /authorize.
# Never set this in production.
# SKIP_FAMULOR_VERIFY=1

# Local dev server port (scripts/serve.ts).
PORT=8787
